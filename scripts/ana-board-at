#!/usr/bin/env sh
set -eu

usage() {
  cat <<'USAGE'
Usage:
  scripts/ana-board-at "2026-05-31T18:30:00+02:00" send [ana-boardctl send args...]
  scripts/ana-board-at "2026-05-31T18:30:00+02:00" frame [ana-boardctl frame args...]

Examples:
  scripts/ana-board-at "2026-05-31T18:30:00+02:00" send --source codex "[amber]REMINDER ⏰"
  scripts/ana-board-at "2026-05-31T18:30:00+02:00" frame --placements-json '[{"row":0,"col":0,"symbol":"A","color":"green"}]'

Set ANA_BOARDCTL=/path/to/ana-boardctl to use a specific binary.
USAGE
}

if [ "$#" -lt 2 ]; then
  usage >&2
  exit 2
fi

at_time=$1
command=$2
shift 2

ana_boardctl=${ANA_BOARDCTL:-ana-boardctl}

case "$command" in
  send|frame)
    exec "$ana_boardctl" "$command" --at "$at_time" "$@"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
